datasource db {
  provider = "postgresql"
}

model user {
  wallet_address String @id @db.VarChar(44)
}

model setting {
  key   String @id @db.VarChar
  value String @db.VarChar
}

model log_memo {
  hash      String @db.VarChar(88)
  log_ix    Int
  timestamp BigInt

  @@id([hash, log_ix])
}

model signing_message {
  address String @id @db.VarChar(44)
  message String @db.VarChar(98)
}
